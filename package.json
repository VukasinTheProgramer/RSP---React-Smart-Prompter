{
  "name": "smartprompting",
  "displayName": "SmartPrompting",
  "description": "React-aware prompt enhancer for AI coding assistants",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartprompting.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "smartprompting.enhancePrompt",
        "title": "SmartPrompting: Enhance Prompt"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "smartprompting",
          "title": "SmartPrompting",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "smartprompting": [
        {
          "id": "smartprompting.panel",
          "name": "SmartPrompting",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "SmartPrompting",
      "properties": {
        "smartprompting.apiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key (aistudio.google.com/apikey, free tier available). Optional — if left blank, falls back to the GEMINI_API_KEY / GOOGLE_API_KEY environment variable."
        },
        "smartprompting.model": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "enum": [
            "gemini-2.5-pro",
            "gemini-2.5-flash",
            "gemini-2.0-flash"
          ],
          "enumDescriptions": [
            "Most capable, best question/prompt quality",
            "Strong quality, faster and cheaper than Pro",
            "Fastest, free-tier friendly"
          ],
          "description": "Gemini model used to generate clarifying questions and expand prompts."
        },
        "smartprompting.maxQuestions": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 3,
          "description": "Max clarifying questions to ask before expanding the prompt. Set to 0 to always skip straight to expansion."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "@google/genai": "^2.10.0"
  }
}
